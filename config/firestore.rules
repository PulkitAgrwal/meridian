rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /corridors/{corridorId} {
      allow read: if request.auth != null;
    }
    match /disruptions/{eventId} {
      allow read: if request.auth != null;
      allow write: if false; // Only agents write via admin SDK
    }
    match /vessels/{mmsi} {
      allow read: if request.auth != null;
    }
    match /reasoning_log/{logId} {
      allow read: if request.auth != null;
    }
  }
}
